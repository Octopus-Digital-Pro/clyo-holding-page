      </a>
      <a href="https://www.facebook.com/SilversandsGrenada/" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" role="presentation" width="20" height="20"><path fill-rule="evenodd" clip-rule="evenodd" d="M22.5 12.605C22.5 6.80654 17.7984 2.10498 12 2.10498C6.20156 2.10498 1.5 6.80654 1.5 12.605C1.5 17.8456 5.33906 22.1895 10.3594 22.978V15.6411H7.69266V12.605H10.3594V10.2917C10.3594 7.66061 11.9273 6.20608 14.3255 6.20608C15.4744 6.20608 16.6763 6.41139 16.6763 6.41139V8.99561H15.3516C14.048 8.99561 13.6402 9.80467 13.6402 10.6362V12.605H16.552L16.087 15.6411H13.6406V22.9789C18.6609 22.1909 22.5 17.847 22.5 12.605Z" fill="currentColor"></path></svg>
      </a>
      <a href="https://www.linkedin.com/company/silversandsgrenada/?originalSubdomain=gd" aria-label="LinkedIn">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none" role="presentation" width="20" height="20"><path fill-rule="evenodd" clip-rule="evenodd" d="M18.4488 11.789V12.669C19.2968 12.141 20.2728 11.837 21.7448 11.837C26.5768 11.837 27.1848 15.437 27.1848 18.589V27.165L21.6008 27.213V19.021C21.6008 17.645 21.1048 17.389 20.1928 17.389C19.2808 17.389 18.7848 17.661 18.7848 19.021V27.213L13.1368 27.165V11.789H18.4328H18.4488ZM10.4168 11.773V27.197H4.80078V11.773H10.4168ZM9.00878 13.181H6.19278V25.789H9.00878V13.181ZM17.0568 13.181H14.5768V25.757L17.4248 25.789V19.005C17.4248 16.365 19.1848 15.965 20.2408 15.965C21.5208 15.965 23.0568 16.493 23.0568 19.005V25.789L25.8248 25.757V18.573C25.8248 14.669 24.7368 13.229 21.7928 13.229C20.0168 13.229 19.2488 13.757 18.4968 14.381L18.3048 14.541H17.0728V13.181H17.0568ZM7.61678 4.74902C9.16878 4.74902 10.4328 6.01302 10.4328 7.56502C10.4328 9.11702 9.16878 10.381 7.61678 10.381C6.06478 10.381 4.80078 9.11702 4.80078 7.56502C4.80078 6.01302 6.06478 4.74902 7.61678 4.74902ZM7.61678 6.15702C6.84878 6.15702 6.20878 6.78102 6.20878 7.56502C6.20878 8.34902 6.83278 8.97302 7.61678 8.97302C8.40078 8.97302 9.02478 8.34902 9.02478 7.56502C9.02478 6.78102 8.40078 6.15702 7.61678 6.15702Z" fill="currentColor"></path></svg>
      </a>
      <a href="https://www.youtube.com/@silversandsgrenada" aria-label="YouTube">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" aria-hidden="true" width="20" height="20"><path d="M23.8428 7.51603C23.8428 5.40666 22.2912 3.70978 20.374 3.70978C17.7772 3.58838 15.1287 3.5415 12.4222 3.5415H11.5784C8.87841 3.5415 6.22529 3.58838 3.62841 3.71025C1.71591 3.71025 0.164348 5.4165 0.164348 7.52588C0.0471601 9.19416 -0.00252745 10.8629 0.000285051 12.5317C-0.00440245 14.2004 0.0487226 15.8707 0.15966 17.5426C0.15966 19.652 1.71122 21.3629 3.62372 21.3629C6.35185 21.4895 9.15029 21.5457 11.9956 21.541C14.8456 21.5504 17.6362 21.491 20.3675 21.3629C22.2847 21.3629 23.8362 19.652 23.8362 17.5426C23.9487 15.8692 24.0003 14.2004 23.9956 12.527C24.0062 10.8582 23.9553 9.18791 23.8428 7.51603ZM9.70341 17.1301V7.91916L16.5003 12.5223L9.70341 17.1301Z" fill="currentColor"></path></svg>
      </a>
    </div>

    <div class="footer-legal container">
      <ul>
        <li><a href="https://beta.clyo.com/terms-and-conditions/">Terms and Conditions</a></li>
        <li><a href="/01%20-%20Introduction.pdf" target="_blank" rel="noopener noreferrer">Privacy Policy</a></li>
        <li><a href="https://beta.clyo.com/cookies-policy/">Cookies Policy</a></li>
      </ul>
      <p>Copyright ©2025 CLYO Hotels &amp; Resorts. All rights reserved</p>
    </div>
  </footer>

  <script>
    const hlsScriptUrl = "https://cdn.jsdelivr.net/npm/hls.js@1.5.20/dist/hls.min.js";

    const loadHlsScript = () => {
      const existingHls = (window as Window & { Hls?: unknown }).Hls;
      if (existingHls) {
        return Promise.resolve();
      }

      return new Promise<void>((resolve, reject) => {
        const script = document.createElement("script");
        script.src = hlsScriptUrl;
        script.async = true;
        script.onload = () => resolve();
        script.onerror = () => reject(new Error("Failed to load HLS runtime."));
        document.head.append(script);
      });
    };

    const initCloudflareHeroVideo = async () => {
      const cloudflareVideo = document.querySelector("[data-cloudflare-video]");
      if (!(cloudflareVideo instanceof HTMLVideoElement)) {
        return;
      }

      const hlsSrc = cloudflareVideo.dataset.cloudflareSrc;
      if (!hlsSrc) {
        return;
      }

      const tryPlay = () => {
        const playAttempt = cloudflareVideo.play();
        if (playAttempt instanceof Promise) {
          playAttempt.catch((error) => {
            console.warn("Cloudflare hero video autoplay was blocked.", error);
          });
        }
      };

      const canPlayNativeHls =
        cloudflareVideo.canPlayType("application/vnd.apple.mpegurl") !== "";

      if (canPlayNativeHls) {
        cloudflareVideo.src = hlsSrc;
        cloudflareVideo.addEventListener("loadedmetadata", tryPlay, { once: true });
        cloudflareVideo.load();
        return;
      }

      try {
        await loadHlsScript();

        const HlsCtor = (
          window as Window & {
            Hls?: {
              isSupported: () => boolean;
              new (): {
                loadSource: (src: string) => void;
                attachMedia: (media: HTMLMediaElement) => void;
              };
            };
          }
        ).Hls;

        if (HlsCtor && HlsCtor.isSupported()) {
          const hls = new HlsCtor();
          cloudflareVideo.addEventListener("canplay", tryPlay, { once: true });
          hls.loadSource(hlsSrc);
          hls.attachMedia(cloudflareVideo);
          return;
        }

        console.warn("Cloudflare hero video could not initialize HLS playback.");
      } catch (error) {
        console.warn("Cloudflare hero video failed to initialize.", error);
      }
    };

    const header = document.querySelector(".site-header");

    if (header instanceof HTMLElement) {
      const handleHeaderScroll = () => {
        header.classList.toggle("is-scrolled", window.scrollY > 0);
      };

      handleHeaderScroll();
      window.addEventListener("scroll", handleHeaderScroll, { passive: true });
    }

    void initCloudflareHeroVideo();

    const RECAPTCHA_SITE_KEY = "6LcviLsrAAAAACjxjvbZp5mhmku9_-DVmPXCDaPd";

    const loadRecaptchaScript = () => {
      if (typeof window === "undefined") return Promise.reject(new Error("reCAPTCHA can only run in the browser."));

      if ((window as typeof window & { grecaptcha?: unknown }).grecaptcha) {
        return Promise.resolve();
      }

      return new Promise<void>((resolve, reject) => {
        const existingScript = document.querySelector<HTMLScriptElement>('script[src^="https://www.google.com/recaptcha/api.js"]');
        if (existingScript) {
          existingScript.addEventListener("load", () => resolve(), { once: true });
          existingScript.addEventListener("error", () => reject(new Error("Failed to load reCAPTCHA script.")), {
            once: true,
          });
          return;
        }

        const script = document.createElement("script");
        script.src = `https://www.google.com/recaptcha/api.js?render=${encodeURIComponent(RECAPTCHA_SITE_KEY)}`;
        script.async = true;
        script.defer = true;
        script.onload = () => resolve();
        script.onerror = () => reject(new Error("Failed to load reCAPTCHA script."));
        document.head.append(script);
      });
    };

    const getRecaptchaToken = async () => {
      if (!RECAPTCHA_SITE_KEY) {
        throw new Error("Missing reCAPTCHA site key.");
      }

      await loadRecaptchaScript();

      const grecaptcha = (window as typeof window & { grecaptcha?: { ready: (cb: () => void) => void; execute: (siteKey: string, options: { action: string }) => Promise<string> } }).grecaptcha;

      if (!grecaptcha) {
        throw new Error("reCAPTCHA is not available on this page.");
      }

      return new Promise<string>((resolve, reject) => {
        grecaptcha.ready(() => {
          grecaptcha
            .execute(RECAPTCHA_SITE_KEY, { action: "contact_form" })
            .then((token: string) => resolve(token))
            .catch((error: unknown) => reject(error));
        });
      });
    };

    const form = document.querySelector("#contact-form");

    if (form instanceof HTMLFormElement) {
      const controls = form.querySelectorAll("input, textarea, select");
      const submitButton = form.querySelector('button[type="submit"]');
      const submitStatus = form.querySelector("[data-submit-status]");
      const endpoint =
        "https://api.clyo.com/umbraco/forms/delivery/api/v1/entries/49ee912c-4928-4b5d-bd5a-3a7768579a17";
      let hasAttemptedSubmit = false;

      const setFieldErrorState = (field: Element) => {
        if (!(field instanceof HTMLInputElement || field instanceof HTMLTextAreaElement || field instanceof HTMLSelectElement)) {
          return;
        }

        const errorTargetName = field.name;
        const errorElement = form.querySelector(`[data-error-for="${errorTargetName}"]`);

        if (!hasAttemptedSubmit) {
          field.setAttribute("aria-invalid", "false");
          if (field.type === "checkbox") {
            const checkboxRow = field.closest("[data-checkbox-row]");
            if (checkboxRow) {
              checkboxRow.setAttribute("data-invalid", "false");
            }
          }
          if (errorElement) {
            errorElement.textContent = "";
          }
          return;
        }

        const isInvalid = !field.checkValidity();

        field.setAttribute("aria-invalid", String(isInvalid));

        if (field.type === "checkbox") {
          const checkboxRow = field.closest("[data-checkbox-row]");
          if (checkboxRow) {
            checkboxRow.setAttribute("data-invalid", String(isInvalid));
          }
        }

        if (errorElement) {
          errorElement.textContent = isInvalid ? field.validationMessage : "";
        }
      };

      controls.forEach((field: Element) => {
        setFieldErrorState(field);
        field.addEventListener("blur", () => setFieldErrorState(field));
        field.addEventListener("input", () => setFieldErrorState(field));
        field.addEventListener("change", () => setFieldErrorState(field));
      });

      form.addEventListener("submit", async (event) => {
        event.preventDefault();
        hasAttemptedSubmit = true;

        const formData = new FormData(form);
        const payload = {
          ...Object.fromEntries(formData.entries()),
          privacyConsent: formData.has("privacyConsent"),
          marketingOptIn: formData.has("marketingOptIn"),
        };

        console.log("Holding page form submission", payload);

        controls.forEach((field: Element) => {
          setFieldErrorState(field);
        });

        if (!form.checkValidity()) {
          console.warn("Form has validation errors.");
          const firstInvalid = form.querySelector('[aria-invalid="true"]');
          if (firstInvalid instanceof HTMLElement) {
            firstInvalid.focus();
          }
          return;
        }

        const values = {
          ...payload,
          domainAddress: window.location.hostname,
        };

        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = true;
        }

        if (submitStatus instanceof HTMLElement) {
          submitStatus.textContent = "Submitting...";
          submitStatus.classList.remove("hidden", "text-[var(--destructive)]");
          submitStatus.classList.add("text-[var(--color-grey)]");
        }

        try {
          const recaptcha = await getRecaptchaToken();

          const body = {
            values: {
              ...values,
              recaptcha,
            },
          };

          const response = await fetch(endpoint, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "Access-Control-Allow-Origin": "*",
              "Access-Control-Allow-Methods": "POST, OPTIONS",
              "Access-Control-Allow-Headers": "Content-Type, Authorization",
            },
            body: JSON.stringify(body),
          });

          if (!response.ok) {
            throw new Error(`Form submission failed with status ${response.status}`);
          }

          console.log("Holding page form submitted", body);

          if (submitStatus instanceof HTMLElement) {
            submitStatus.textContent = "Thank you. Your message has been submitted.";
            submitStatus.classList.remove("text-[var(--destructive)]", "text-[var(--color-grey)]");
            submitStatus.classList.add("text-[var(--color-night)]");
          }

          form.reset();
          hasAttemptedSubmit = false;
          controls.forEach((field: Element) => {
            setFieldErrorState(field);
          });
        } catch (error) {
          console.error("Holding page form submission failed", error);

          if (submitStatus instanceof HTMLElement) {
            submitStatus.textContent =
              "Something went wrong while submitting the form. Please try again.";
            submitStatus.classList.remove("hidden", "text-[var(--color-grey)]");
            submitStatus.classList.add("text-[var(--destructive)]");
          }
        } finally {
          if (submitButton instanceof HTMLButtonElement) {
            submitButton.disabled = false;
          }
        }
      });
    }
  </script>
</BaseLayout>
