---
import BaseLayout from "../layouts/BaseLayout.astro";

const heroMedia = {
  imageSrc: "/hero-image.webp",
  imageAlt: "A serene resort pool lined with palm trees at sunset.",
  // Set a value like "/hero-video.mp4" to enable hero video.
  videoSrc: "",
  // Set a Cloudflare Stream video ID to use the embedded player.
  cloudflareVideoId: "9de23cd6caa7a5f4911f3ae0150904d2",
  // cloudflareVideoId: "eed4e42ee04b928636db671c94812677",
};
const cloudflareHlsSrc = heroMedia.cloudflareVideoId
  ? `https://videodelivery.net/${heroMedia.cloudflareVideoId}/manifest/video.m3u8`
  : "";

const inputClasses =
  "h-[42px] w-full rounded-[6px] border border-[var(--color-ivory)] bg-transparent px-[14px] py-[10px] font-[var(--font-serif)] text-[14px] leading-[18px] text-[var(--color-night)] outline-none placeholder:text-(--color-cloud-white)/80 focus:border-[var(--color-sky-blue)] aria-[invalid=true]:border-[var(--destructive)] aria-[invalid=true]:focus:shadow-[0_0_0_3px_oklch(0.577_0.245_27.325_/_0.2)]";
const checkboxClasses =
  " h-[14px] w-[14px] shrink-0 rounded-[2px] border border-[var(--color-ivory)] bg-transparent focus-visible:outline focus-visible:outline-1 focus-visible:outline-offset-1 focus-visible:outline-[var(--color-cloud-white)] aria-[invalid=true]:outline aria-[invalid=true]:outline-1 aria-[invalid=true]:outline-[var(--destructive)] aria-[invalid=true]:outline-offset-1";
const errorClasses =
  "mt-[6px] hidden font-[var(--font-sans)] text-[12px] leading-[16px] text-[var(--destructive)] not-empty:block";
const checkboxRowClasses =
  "flex items-center justify-center gap-[10px] font-[var(--font-serif)] text-[14px] leading-[18px] data-[invalid=true]:text-[var(--destructive)] [&_a]:underline";
const submitButtonClasses =
  "inline-flex w-fit items-center justify-center gap-4 rounded-[10px] border border-[var(--color-ivory)] bg-transparent px-5 py-[10px] font-[var(--font-sans)] text-[12px] font-medium uppercase tracking-[1px] leading-[16px] text-[var(--color-night)] transition hover:bg-[rgba(224,208,184,0.25)] xl:px-[32px] xl:text-[14px] xl:leading-[18px] hover:cursor-pointer";
---

<BaseLayout title="CLYO Hotels & Resorts" description="CLYO Hotels & Resorts.">
  <main>
    <section class="h-screen w-full" aria-label="Hero image">
      <div
        class="relative h-screen w-full overflow-hidden bg-(--color-cloud-white)"
      >
        {
          heroMedia.cloudflareVideoId ? (
            <div class="relative h-full w-full">
              <img
                class="block h-full w-full object-cover object-center transition-opacity duration-500"
                data-hero-fallback
                src={heroMedia.imageSrc}
                alt={heroMedia.imageAlt}
                loading="eager"
              />
              <video
                class="absolute inset-0 block h-full w-full object-cover object-center opacity-0 transition-opacity duration-500"
                data-hero-video
                data-cloudflare-video
                data-cloudflare-src={cloudflareHlsSrc}
                autoplay
                loop
                playsinline
                preload="metadata"
                poster={heroMedia.imageSrc}
                crossorigin="anonymous"
                aria-label={heroMedia.imageAlt}
              >
                <source src={cloudflareHlsSrc} type="application/x-mpegURL" />
              </video>
            </div>
          ) : heroMedia.videoSrc ? (
            <div class="relative h-full w-full">
              <img
                class="block h-full w-full object-cover object-center transition-opacity duration-500"
                data-hero-fallback
                src={heroMedia.imageSrc}
                alt={heroMedia.imageAlt}
                loading="eager"
              />
              <video
                class="absolute inset-0 block h-full w-full object-cover object-center opacity-0 transition-opacity duration-500"
                data-hero-video
                autoplay
                loop
                playsinline
                preload="metadata"
                poster={heroMedia.imageSrc}
                aria-label={heroMedia.imageAlt}
              >
                <source src={heroMedia.videoSrc} type="video/mp4" />
              </video>
            </div>
          ) : (
            <img
              class="block h-full w-full object-cover object-center"
              src={heroMedia.imageSrc}
              alt={heroMedia.imageAlt}
              loading="eager"
            />
          )
        }
        <div
          class="absolute inset-0 z-10 bg-[linear-gradient(to_bottom,rgba(16,24,32,0.396)_0%,rgba(16,24,32,0.495)_25%,rgba(16,24,32,0.495)_75%,rgba(16,24,32,0.396)_100%)]"
          aria-hidden="true"
        >
        </div>

        <div
          class="absolute inset-0 z-20 h-full w-full px-4 py-6 text-(--color-cloud-white) md:py-8 xl:py-10"
        >
          <div class="relative z-10 flex items-center justify-center">
            <img
              src="/CLYO_Hotels&Resorts_CloudWhite-01.png"
              alt="CLYO Hotels and Resorts"
              class="w-24 h-auto brightness-0 invert"
            />
          </div>

          <div
            class="absolute inset-0 flex items-center justify-center px-4 text-center"
          >
            <div
              class="mb-16 flex w-full flex-col items-center justify-center md:max-w-[85vw]"
            >
              <h1
                class="text-[48px] font-serif leading-none font-light tracking-tight mb-8"
                style="animation-delay:0s"
              >
                Coming Soon
              </h1>
              <p
                class="w-full max-w-[680px] text-[16px] font-serif leading-[1.2] font-light tracking-tight md:text-[18px] xl:text-[20px]"
              >
                When the sun rises, we stir. When it’s time to move, we dance. <br
                />
                When curiosity calls, we discover. In nature. In luxury. In every
                memory.
              </p>
            </div>
          </div>

          <form
            class="absolute left-1/2 top-[calc(50%+clamp(5.5rem,10vh,8.5rem))] z-10 grid w-[calc(100%-2rem)] max-w-[348px] -translate-x-1/2 gap-6"
            id="contact-form"
            novalidate
          >
            <div class="grid gap-4">
              <label class="block">
                <span
                  class="absolute -m-px h-px w-px overflow-hidden whitespace-nowrap border-0 p-0 [clip:rect(0,0,0,0)]"
                >
                  Email Address
                </span>
                <input
                  id="emailAddress"
                  class={inputClasses}
                  type="email"
                  name="emailAddress"
                  placeholder="Email address*"
                  required
                />
                <p
                  class={errorClasses}
                  data-error-for="emailAddress"
                  aria-live="polite"
                >
                </p>
              </label>
            </div>

            <fieldset class="grid gap-[14px] border-0 p-0 m-0">
              <legend
                class="absolute -m-px h-px w-px overflow-hidden whitespace-nowrap border-0 p-0 [clip:rect(0,0,0,0)]"
              >
                Consent
              </legend>
              <label
                class={checkboxRowClasses}
                data-checkbox-row
                data-invalid="false"
              >
                <input
                  id="privacyConsent"
                  class={checkboxClasses}
                  data-consent-checkbox
                  type="checkbox"
                  name="privacyConsent"
                  required
                />
                <span>
                  I agree to receive emails from CLYO. See
                  <a
                    class="underline"
                    href="/01%20-%20Introduction.pdf"
                    target="_blank"
                    rel="noopener noreferrer"
                  >
                    Privacy Policy
                  </a>
                  .
                </span>
              </label>
              <p
                class="mt-[-6px] hidden font-(--font-sans) text-[12px] leading-[16px] text-(--destructive) not-empty:block"
                data-error-for="privacyConsent"
                aria-live="polite"
              >
              </p>
            </fieldset>

            <div class="flex justify-center">
              <button class={submitButtonClasses} type="submit">
                <span>Stay tuned</span>
                <svg
                  viewBox="0 0 24 24"
                  width="16"
                  height="16"
                  fill="none"
                  aria-hidden="true"
                >
                  <path
                    d="M5 12H19"
                    stroke="currentColor"
                    stroke-width="1.2"
                    stroke-linecap="round"></path>
                  <path
                    d="M12 5L19 12L12 19"
                    stroke="currentColor"
                    stroke-width="1.2"
                    stroke-linecap="round"
                    stroke-linejoin="round"></path>
                </svg>
              </button>
            </div>
            <p
              class="hidden text-center font-(--font-sans) text-[12px] leading-[16px]"
              data-submit-status
              aria-live="polite"
            >
            </p>
          </form>
          <button
            type="button"
            class="absolute bottom-6 right-6 z-30 hover:cursor-pointer inline-flex h-12 w-12 items-center justify-center"
            data-video-mute-toggle
            aria-label="Mute video"
          >
            <img
              src="/sound-on.svg"
              alt=""
              aria-hidden="true"
              class="h-9 w-9"
              data-video-mute-icon
            />
          </button>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>

<script>
  const hlsScriptUrl =
    "https://cdn.jsdelivr.net/npm/hls.js@1.5.20/dist/hls.min.js";

  const initHeroVideoReveal = () => {
    const heroVideo = document.querySelector("[data-hero-video]");
    const heroFallback = document.querySelector("[data-hero-fallback]");
    if (
      !(heroVideo instanceof HTMLVideoElement) ||
      !(heroFallback instanceof HTMLImageElement)
    ) {
      return;
    }

    const revealVideo = () => {
      heroVideo.classList.remove("opacity-0");
      heroFallback.classList.add("opacity-0");
      heroFallback.setAttribute("aria-hidden", "true");
    };

    if (heroVideo.readyState >= HTMLMediaElement.HAVE_CURRENT_DATA) {
      revealVideo();
    }

    heroVideo.addEventListener("loadeddata", revealVideo, { once: true });
    heroVideo.addEventListener("canplay", revealVideo, { once: true });
    heroVideo.addEventListener("error", () => {
      heroVideo.classList.add("opacity-0");
      heroFallback.classList.remove("opacity-0");
      heroFallback.removeAttribute("aria-hidden");
    });
  };

  const initHeroVideoAudioControl = () => {
    const heroVideo = document.querySelector("[data-hero-video]");
    const muteToggle = document.querySelector("[data-video-mute-toggle]");
    const muteIcon = document.querySelector("[data-video-mute-icon]");
    if (
      !(heroVideo instanceof HTMLVideoElement) ||
      !(muteToggle instanceof HTMLButtonElement) ||
      !(muteIcon instanceof HTMLImageElement)
    ) {
      return;
    }

    heroVideo.muted = false;
    heroVideo.volume = 1;

    const updateMuteButton = () => {
      const isMuted = heroVideo.muted || heroVideo.volume === 0;
      muteToggle.setAttribute("aria-pressed", String(isMuted));
      muteToggle.setAttribute(
        "aria-label",
        isMuted ? "Unmute video" : "Mute video",
      );
      muteToggle.classList.toggle("opacity-70", isMuted);
      muteIcon.src = isMuted ? "/mute.svg" : "/sound-on.svg";
    };

    muteToggle.addEventListener("click", () => {
      const shouldMute = !(heroVideo.muted || heroVideo.volume === 0);
      heroVideo.muted = shouldMute;
      if (!shouldMute && heroVideo.volume === 0) {
        heroVideo.volume = 1;
      }
      updateMuteButton();
    });

    updateMuteButton();
  };

  const loadHlsScript = () => {
    const existingHls = (window as Window & { Hls?: unknown }).Hls;
    if (existingHls) {
      return Promise.resolve();
    }

    return new Promise<void>((resolve, reject) => {
      const script = document.createElement("script");
      script.src = hlsScriptUrl;
      script.async = true;
      script.onload = () => resolve();
      script.onerror = () => reject(new Error("Failed to load HLS runtime."));
      document.head.append(script);
    });
  };

  const initCloudflareHeroVideo = async () => {
    const cloudflareVideo = document.querySelector("[data-cloudflare-video]");
    if (!(cloudflareVideo instanceof HTMLVideoElement)) {
      return;
    }

    const hlsSrc = cloudflareVideo.dataset.cloudflareSrc;
    if (!hlsSrc) {
      return;
    }

    const tryPlay = () => {
      const playAttempt = cloudflareVideo.play();
      if (playAttempt instanceof Promise) {
        playAttempt.catch((error) => {
          console.warn("Cloudflare hero video autoplay was blocked.", error);
        });
      }
    };

    cloudflareVideo.muted = false;
    cloudflareVideo.volume = 1;

    const canPlayNativeHls =
      cloudflareVideo.canPlayType("application/vnd.apple.mpegurl") !== "";

    if (canPlayNativeHls) {
      cloudflareVideo.src = hlsSrc;
      cloudflareVideo.addEventListener("loadedmetadata", tryPlay, {
        once: true,
      });
      cloudflareVideo.load();
      return;
    }

    try {
      await loadHlsScript();

      const HlsCtor = (
        window as Window & {
          Hls?: {
            isSupported: () => boolean;
            new (): {
              loadSource: (src: string) => void;
              attachMedia: (media: HTMLMediaElement) => void;
            };
          };
        }
      ).Hls;

      if (HlsCtor && HlsCtor.isSupported()) {
        const hls = new HlsCtor();
        cloudflareVideo.addEventListener("canplay", tryPlay, { once: true });
        hls.loadSource(hlsSrc);
        hls.attachMedia(cloudflareVideo);
        return;
      }

      console.warn("Cloudflare hero video could not initialize HLS playback.");
    } catch (error) {
      console.warn("Cloudflare hero video failed to initialize.", error);
    }
  };

  initHeroVideoReveal();
  initHeroVideoAudioControl();
  void initCloudflareHeroVideo();

  const heroVideo = document.querySelector("[data-hero-video]");
  if (heroVideo instanceof HTMLVideoElement) {
    const ensurePlayWithSound = () => {
      heroVideo.muted = false;
      heroVideo.volume = 1;
      const attempt = heroVideo.play();
      if (attempt instanceof Promise) {
        attempt.catch(() => {
          // Some browsers block unmuted autoplay until user interaction.
        });
      }
    };

    ensurePlayWithSound();
    window.addEventListener("pointerdown", ensurePlayWithSound, { once: true });
    window.addEventListener("keydown", ensurePlayWithSound, { once: true });
  }

  const RECAPTCHA_SITE_KEY = "6LcviLsrAAAAACjxjvbZp5mhmku9_-DVmPXCDaPd";

  const loadRecaptchaScript = () => {
    if (typeof window === "undefined")
      return Promise.reject(
        new Error("reCAPTCHA can only run in the browser."),
      );

    if ((window as typeof window & { grecaptcha?: unknown }).grecaptcha) {
      return Promise.resolve();
    }

    return new Promise<void>((resolve, reject) => {
      const existingScript = document.querySelector<HTMLScriptElement>(
        'script[src^="https://www.google.com/recaptcha/api.js"]',
      );
      if (existingScript) {
        existingScript.addEventListener("load", () => resolve(), {
          once: true,
        });
        existingScript.addEventListener(
          "error",
          () => reject(new Error("Failed to load reCAPTCHA script.")),
          {
            once: true,
          },
        );
        return;
      }

      const script = document.createElement("script");
      script.src = `https://www.google.com/recaptcha/api.js?render=${encodeURIComponent(RECAPTCHA_SITE_KEY)}`;
      script.async = true;
      script.defer = true;
      script.onload = () => resolve();
      script.onerror = () =>
        reject(new Error("Failed to load reCAPTCHA script."));
      document.head.append(script);
    });
  };

  const getRecaptchaToken = async () => {
    if (!RECAPTCHA_SITE_KEY) {
      throw new Error("Missing reCAPTCHA site key.");
    }

    await loadRecaptchaScript();

    const grecaptcha = (
      window as typeof window & {
        grecaptcha?: {
          ready: (cb: () => void) => void;
          execute: (
            siteKey: string,
            options: { action: string },
          ) => Promise<string>;
        };
      }
    ).grecaptcha;

    if (!grecaptcha) {
      throw new Error("reCAPTCHA is not available on this page.");
    }

    return new Promise<string>((resolve, reject) => {
      grecaptcha.ready(() => {
        grecaptcha
          .execute(RECAPTCHA_SITE_KEY, { action: "contact_form" })
          .then((token: string) => resolve(token))
          .catch((error: unknown) => reject(error));
      });
    });
  };

  const form = document.querySelector("#contact-form");

  if (form instanceof HTMLFormElement) {
    const controls = form.querySelectorAll("input, textarea, select");
    const submitButton = form.querySelector('button[type="submit"]');
    const submitStatus = form.querySelector("[data-submit-status]");
    const endpoint =
      "https://api.clyo.com/umbraco/forms/delivery/api/v1/entries/42911cd0-25e9-40f2-818d-550e6211bbe0";
    let hasAttemptedSubmit = false;

    const setFieldErrorState = (field: Element) => {
      if (
        !(
          field instanceof HTMLInputElement ||
          field instanceof HTMLTextAreaElement ||
          field instanceof HTMLSelectElement
        )
      ) {
        return;
      }

      const errorTargetName = field.name;
      const errorElement = form.querySelector(
        `[data-error-for="${errorTargetName}"]`,
      );

      if (!hasAttemptedSubmit) {
        field.setAttribute("aria-invalid", "false");
        if (field.type === "checkbox") {
          const checkboxRow = field.closest("[data-checkbox-row]");
          if (checkboxRow) {
            checkboxRow.setAttribute("data-invalid", "false");
          }
        }
        if (errorElement) {
          errorElement.textContent = "";
        }
        return;
      }

      const isInvalid = !field.checkValidity();

      field.setAttribute("aria-invalid", String(isInvalid));

      if (field.type === "checkbox") {
        const checkboxRow = field.closest("[data-checkbox-row]");
        if (checkboxRow) {
          checkboxRow.setAttribute("data-invalid", String(isInvalid));
        }
      }

      if (errorElement) {
        errorElement.textContent = isInvalid ? field.validationMessage : "";
      }
    };

    controls.forEach((field: Element) => {
      setFieldErrorState(field);
      field.addEventListener("blur", () => setFieldErrorState(field));
      field.addEventListener("input", () => setFieldErrorState(field));
      field.addEventListener("change", () => setFieldErrorState(field));
    });

    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      hasAttemptedSubmit = true;

      const formData = new FormData(form);
      const payload = {
        ...Object.fromEntries(formData.entries()),
        privacyConsent: formData.has("privacyConsent"),
      };

      console.log("Holding page form submission", payload);

      controls.forEach((field: Element) => {
        setFieldErrorState(field);
      });

      if (!form.checkValidity()) {
        console.warn("Form has validation errors.");
        const firstInvalid = form.querySelector('[aria-invalid="true"]');
        if (firstInvalid instanceof HTMLElement) {
          firstInvalid.focus();
        }
        return;
      }

      const values = {
        ...payload,
        domainAddress: window.location.hostname,
      };

      if (submitButton instanceof HTMLButtonElement) {
        submitButton.disabled = true;
      }

      if (submitStatus instanceof HTMLElement) {
        submitStatus.textContent = "Submitting...";
        submitStatus.classList.remove("hidden", "text-[var(--destructive)]");
        submitStatus.classList.add("text-[var(--color-grey)]");
      }

      try {
        const recaptcha = await getRecaptchaToken();

        const body = {
          values: {
            ...values,
            recaptcha,
          },
        };

        const response = await fetch(endpoint, {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(body),
        });

        if (!response.ok) {
          throw new Error(
            `Form submission failed with status ${response.status}`,
          );
        }

        console.log("Holding page form submitted", body);

        if (submitStatus instanceof HTMLElement) {
          submitStatus.textContent =
            "You’re signed up. We’ll be in touch soon.";
          submitStatus.classList.remove(
            "text-[var(--destructive)]",
            "text-[var(--color-grey)]",
          );
          submitStatus.classList.add("text-(--color-cloud-white)");
        }

        form.reset();
        hasAttemptedSubmit = false;
        controls.forEach((field: Element) => {
          setFieldErrorState(field);
        });
      } catch (error) {
        console.error("Holding page form submission failed", error);

        if (submitStatus instanceof HTMLElement) {
          submitStatus.textContent =
            "Something went wrong while submitting the form. Please try again.";
          submitStatus.classList.remove("hidden", "text-[var(--color-grey)]");
          submitStatus.classList.add("text-[var(--destructive)]");
        }
      } finally {
        if (submitButton instanceof HTMLButtonElement) {
          submitButton.disabled = false;
        }
      }
    });
  }
</script>

<style>
  [data-consent-checkbox] {
    appearance: none;
    -webkit-appearance: none;
    position: relative;
    display: inline-block;
    cursor: pointer;
    transition: box-shadow 150ms ease;
  }

  [data-consent-checkbox]:checked {
    background-color: var(--color-sky-blue);
  }

  [data-consent-checkbox]:checked::after {
    content: "";
    position: absolute;
    left: 4px;
    top: 1px;
    width: 4px;
    height: 8px;
    border: solid var(--color-cloud-white);
    border-width: 0 2px 2px 0;
    transform: rotate(45deg);
  }
</style>
