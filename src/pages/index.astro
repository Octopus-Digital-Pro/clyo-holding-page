---
import BaseLayout from "../layouts/BaseLayout.astro";

const heroMedia = {
  imageSrc: "/hero-image.webp",
  imageAlt: "A serene resort pool lined with palm trees at sunset.",
  // Set a value like "/hero-video.mp4" to enable hero video.
  videoSrc: "",
  // Set a Cloudflare Stream video ID to use the embedded player.
  cloudflareVideoId: "",
};
const cloudflareHlsSrc = heroMedia.cloudflareVideoId
  ? `https://videodelivery.net/${heroMedia.cloudflareVideoId}/manifest/video.m3u8`
  : "";

const inputClasses =
  "h-[42px] w-full rounded-[6px] border border-[var(--color-ivory)] bg-transparent px-[14px] py-[10px] font-[var(--font-serif)] text-[14px] leading-[18px] text-[var(--color-night)] outline-none placeholder:text-[rgba(16,24,32,0.6)] focus:border-[var(--color-sky-blue)] aria-[invalid=true]:border-[var(--destructive)] aria-[invalid=true]:focus:shadow-[0_0_0_3px_oklch(0.577_0.245_27.325_/_0.2)]";
const checkboxClasses =
  "mt-[2px] h-[14px] w-[14px] shrink-0 accent-[var(--color-sky-blue)] aria-[invalid=true]:outline aria-[invalid=true]:outline-1 aria-[invalid=true]:outline-[var(--destructive)] aria-[invalid=true]:outline-offset-1";
const errorClasses =
  "mt-[6px] hidden font-[var(--font-sans)] text-[12px] leading-[16px] text-[var(--destructive)] not-empty:block";
const checkboxRowClasses =
  "flex items-start gap-[10px] font-[var(--font-serif)] text-[14px] leading-[18px] data-[invalid=true]:text-[var(--destructive)] [&_a]:underline";
const submitButtonClasses =
  "inline-flex min-w-[142px] items-center justify-center gap-6 rounded-[10px] border border-[var(--color-ivory)] bg-transparent px-7 py-[14px] font-[var(--font-sans)] text-[12px] font-medium uppercase tracking-[1px] leading-[16px] text-[var(--color-night)] transition hover:bg-[rgba(224,208,184,0.25)] xl:px-[50px] xl:text-[14px] xl:leading-[18px]";
---

<BaseLayout
  title="CLYO Hotels & Resorts"
  description="A lightweight holding page for CLYO Hotels & Resorts."
>
  <header class="site-header">
    <nav class="nav-shell container" aria-label="Main">
      <a class="brand-mark" href="/" aria-label="CLYO home">
        <div class="brand-mark-frame">
          <img src="/logo.svg" alt="CLYO" width="190" height="40" />
        </div>
      </a>
    </nav>
  </header>

  <main>
    <section class="hero-section container" aria-label="Hero image">
      <div class="hero-frame">
        {
          heroMedia.cloudflareVideoId ? (
            <video
              class="hero-media"
              data-cloudflare-video
              data-cloudflare-src={cloudflareHlsSrc}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              poster={heroMedia.imageSrc}
              crossorigin="anonymous"
              aria-label={heroMedia.imageAlt}
            >
              <source src={cloudflareHlsSrc} type="application/x-mpegURL" />
            </video>
          ) : heroMedia.videoSrc ? (
            <video
              class="hero-media"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              poster={heroMedia.imageSrc}
              aria-label={heroMedia.imageAlt}
            >
              <source src={heroMedia.videoSrc} type="video/mp4" />
            </video>
          ) : (
            <img class="hero-media" src={heroMedia.imageSrc} alt={heroMedia.imageAlt} loading="eager" />
          )
        }

        <div class="hero-overlay-bottom" aria-hidden="true"></div>

        <div class="hero-heading">
          <div
            role="heading"
            aria-level="1"
            class="heading-text-1 text-[62px] font-serif leading-none line font-light tracking-tight group-data-[inview=true]:animate-slide-up"
            style="animation-delay:0s"
          >
            <h1>CLYO Hotels and Resorts Coming Soon</h1>
          </div>
        </div>
      </div>
    </section>

    <section class="container flex flex-col items-center gap-[30px] px-4 py-[30px] pb-[56px] xl:p-[60px]">
      <div class="grid w-full max-w-[648px] justify-items-center gap-6 text-center">
        <p class="heading-text-subheading">Contact Us</p>
        <div class="font-serif text-[36px] font-light leading-[41px] tracking-[-1px] capitalize xl:text-[40px] xl:leading-[46px]">
          <p>We&apos;d Love To Hear From You</p>
        </div>
        <div class="font-serif text-[16px] leading-6 xl:text-[18px] xl:leading-[27px] [&_a]:underline [&_p]:m-0">
          <p>
            By subscribing, you agree to receive updates from us. Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt ut labore et dolore magna aliqua. 
          </p>
        </div>
      </div>

      <form class="grid w-full max-w-[648px] gap-6" id="contact-form" novalidate>
        <div class="grid grid-cols-2 gap-4">
          <label class="block">
            <span class="sr-only">Full Name</span>
            <input id="name" class={inputClasses} type="text" name="name" placeholder="Full name*" required />
            <p class={errorClasses} data-error-for="name" aria-live="polite"></p>
          </label>
          <label class="block">
            <span class="sr-only">Email Address</span>
            <input
              id="emailAddress"
              class={inputClasses}
              type="email"
              name="emailAddress"
              placeholder="Email address*"
              required
            />
            <p class={errorClasses} data-error-for="emailAddress" aria-live="polite"></p>
          </label>
        </div>

        <fieldset class="grid gap-[14px] border-0 p-0 m-0">
          <legend class="sr-only">Consent</legend>
          <label class={checkboxRowClasses} data-checkbox-row data-invalid="false">
            <input id="privacyConsent" class={checkboxClasses} type="checkbox" name="privacyConsent" required />
            <span>
              I have read and agree to the
              <a href="/01%20-%20Introduction.pdf" target="_blank" rel="noopener noreferrer">
                Privacy Policy
              </a>
            </span>
          </label>
          <p
            class="mt-[-6px] hidden font-[var(--font-sans)] text-[12px] leading-[16px] text-[var(--destructive)] not-empty:block"
            data-error-for="privacyConsent"
            aria-live="polite"
          ></p>
          <label class={checkboxRowClasses} data-checkbox-row data-invalid="false">
            <input class={checkboxClasses} type="checkbox" name="marketingOptIn" />
            <span>Yes, I would like to receive emails with exclusive specials and offers.</span>
          </label>
        </fieldset>

        <div class="flex justify-center">
          <button class={submitButtonClasses} type="submit">
            <span>Submit</span>
            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" aria-hidden="true">
              <path d="M5 12H19" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"></path>
              <path
                d="M12 5L19 12L12 19"
                stroke="currentColor"
                stroke-width="1.2"
                stroke-linecap="round"
                stroke-linejoin="round"></path>
            </svg>
          </button>
        </div>
        <p
          class="hidden text-center font-[var(--font-sans)] text-[12px] leading-[16px]"
          data-submit-status
          aria-live="polite"
        ></p>
      </form>
    </section>
  </main>

  <footer class="site-footer">


    <div class="footer-social container" aria-label="Social links">
      <a href="https://www.instagram.com/silversandsgrenada/" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" role="presentation" width="20" height="20"><path d="M16.3748 3.79232C17.5342 3.79579 18.6451 4.25787 19.4648 5.07765C20.2846 5.89743 20.7467 7.0083 20.7502 8.16764V16.9173C20.7467 18.0767 20.2846 19.1875 19.4648 20.0073C18.6451 20.8271 17.5342 21.2892 16.3748 21.2926H7.62516C6.46582 21.2892 5.35495 20.8271 4.53517 20.0073C3.71539 19.1875 3.25331 18.0767 3.24984 16.9173V8.16764C3.25331 7.0083 3.71539 5.89743 4.53517 5.07765C5.35495 4.25787 6.46582 3.79579 7.62516 3.79232H16.3748ZM16.3748 2.04248H7.62516C4.25625 2.04248 1.5 4.79873 1.5 8.16764V16.9173C1.5 20.2862 4.25625 23.0425 7.62516 23.0425H16.3748C19.7437 23.0425 22.5 20.2862 22.5 16.9173V8.16764C22.5 4.79873 19.7437 2.04248 16.3748 2.04248Z" fill="currentColor"></path><path d="M17.6913 8.175C17.4309 8.175 17.1764 8.0978 16.96 7.95317C16.7435 7.80854 16.5748 7.60297 16.4752 7.36245C16.3756 7.12194 16.3495 6.85728 16.4003 6.60195C16.4511 6.34662 16.5764 6.11209 16.7605 5.928C16.9446 5.74392 17.1791 5.61856 17.4345 5.56777C17.6898 5.51698 17.9545 5.54305 18.195 5.64268C18.4355 5.7423 18.6411 5.91101 18.7857 6.12747C18.9303 6.34392 19.0075 6.59841 19.0075 6.85874C19.0079 7.0317 18.9741 7.20303 18.9081 7.36289C18.8421 7.52275 18.7451 7.66801 18.6228 7.79031C18.5005 7.91261 18.3553 8.00955 18.1954 8.07556C18.0355 8.14158 17.8642 8.17537 17.6913 8.175Z" fill="currentColor"></path><path d="M12 9.04086C12.6923 9.04086 13.369 9.24614 13.9446 9.63074C14.5202 10.0153 14.9688 10.562 15.2337 11.2016C15.4986 11.8411 15.568 12.5449 15.4329 13.2239C15.2978 13.9028 14.9645 14.5265 14.475 15.016C13.9855 15.5055 13.3618 15.8389 12.6828 15.9739C12.0039 16.109 11.3001 16.0397 10.6606 15.7747C10.021 15.5098 9.47433 15.0612 9.08973 14.4856C8.70513 13.91 8.49985 13.2333 8.49985 12.541C8.50084 11.613 8.86992 10.7233 9.52611 10.0671C10.1823 9.41094 11.072 9.04185 12 9.04086ZM12 7.29102C10.9617 7.29102 9.94662 7.59892 9.08326 8.1758C8.2199 8.75268 7.54699 9.572